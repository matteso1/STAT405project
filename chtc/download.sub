# Kaggle download as a Condor job (the login node OOMs).
universe       = vanilla
executable     = download.sh

log    = download.log
output = download.out
error  = download.err

should_transfer_files   = YES
when_to_transfer_output = ON_EXIT
transfer_input_files    = $ENV(HOME)/.kaggle/kaggle.json

request_cpus   = 1
request_memory = 4GB
request_disk   = 80GB

requirements   = (HasCHTCStaging == true)

queue 1
